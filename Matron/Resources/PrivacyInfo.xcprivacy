<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
	Privacy manifest for the iOS app. Required by App Store Connect: an
	upload that uses a "required reason" API without declaring it here is
	rejected with ITMS-91053 ("Missing API declaration").

	Every entry below was derived from a grep of the shipping code, not from
	a template — see docs/app-store-submission.md for the audit. The
	MatronNSE extension has no manifest because it links nothing and uses no
	required-reason API; add one there the moment that changes.

	NSPrivacyCollectedDataTypes is a DRAFT PENDING DAN'S SIGN-OFF. It
	describes what the client demonstrably transmits, and it must agree with
	the App Privacy answers in App Store Connect. The judgement call it
	encodes: the journal server stores messages, and the default deployment
	is a server Dan operates, so that content counts as "collected". If a
	user self-hosts, the same data never reaches the developer — but the
	declaration has to describe the shipping default.
-->
<plist version="1.0">
<dict>
	<key>NSPrivacyTracking</key>
	<false/>
	<!--
		No data is shared with data brokers or used to track across apps or
		websites owned by other companies, so this stays empty. Any future
		analytics or ad SDK makes both this and NSPrivacyTracking wrong.
	-->
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!--
				UserDefaults: appearance setting (MatronAppearance), recent
				/start folders (RecentStartFolders), answered ask-user
				prompts (ChatViewModel), the MatronDebug flag, and the Mac
				window defaults. All of it is read and written through
				`UserDefaults.standard` — app-local only. No app-group suite
				is used in shipping code (only tests construct suites), which
				is exactly what CA92.1 covers.
			-->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
		<dict>
			<!--
				FileManager.attributesOfItem(atPath:) in SearchSchema, which
				asserts NSFileProtectionComplete on the search index. It reads
				.protectionKey rather than a timestamp, and it's gated to
				`#if os(iOS) && !targetEnvironment(simulator)` — so this is
				declared defensively: Apple's static check flags the call
				site, and the file it inspects is inside our own container,
				which is precisely what C617.1 describes. (The Mac manifest
				omits this: that code path is iOS-only.)
			-->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>C617.1</string>
			</array>
		</dict>
	</array>
	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<dict>
			<!-- Sign-in identity for the journal server. -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeEmailAddress</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<!-- The account identifier the journal server keys sessions on. -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeUserID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<!-- Chat messages to and from the agent. -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeEmailsOrTextMessages</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<!-- Photo attachments (picker, file importer, paste). -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypePhotosorVideos</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<!-- Voice notes (VoiceRecorder → audio/mp4 attachment). -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeAudioData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<!-- Non-image file attachments sent to the agent. -->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeOtherUserContent</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
		<dict>
			<!--
				The APNs device token, registered with the journal server so
				it can wake this install. Not an advertising identifier and
				never used for tracking.
			-->
			<key>NSPrivacyCollectedDataType</key>
			<string>NSPrivacyCollectedDataTypeDeviceID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key>
			<true/>
			<key>NSPrivacyCollectedDataTypeTracking</key>
			<false/>
			<key>NSPrivacyCollectedDataTypePurposes</key>
			<array>
				<string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
