<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<!--
		Microphone access for voice-note recording. Required only by the
		sandboxed Release build; the Debug / Debug.AdHoc variants run with
		the sandbox OFF (see the header of those files), so they don't need
		it. Pairs with NSMicrophoneUsageDescription (set via project.yml).
	-->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<key>com.apple.security.files.user-selected.read-only</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)chat.matron.mac</string>
	</array>
	<!--
		Phase 4 Task 12: APNs environment for Release / App Store
		builds. Pairs with `use_sandbox: false` on the matching Sygnal
		`app_id` (`chat.matron.mac`). Notarized + Mac App Store builds
		hit production APNs; Debug builds use `MatronMac.Debug.entitlements`
		with `com.apple.developer.aps-environment=development` instead.

		**macOS-specific key**: macOS uses
		`com.apple.developer.aps-environment` (NOT the iOS-only bare
		`aps-environment`) per Apple's macOS entitlements docs. The
		Debug variant has the same comment.
	-->
	<key>com.apple.developer.aps-environment</key>
	<string>production</string>
</dict>
</plist>
